# Copy to .env.local and adjust paths for your machine. No secrets here.
REPO_ROOT=D:\Test Script
PYTHON_EXE=D:\Test Script\.venv\Scripts\python.exe
HOST=127.0.0.1
PORT=3000

# --- Team run sharing (optional) ---
# Point this at a folder synced by everyone's OneDrive client (e.g. a shared
# Teams/SharePoint folder each teammate has added to their own OneDrive) to make
# runs visible to the whole team. Each person's app only ever WRITES its own
# TEAM_RUNS_ROOT\TEAM_MEMBER subfolder — never anyone else's — so there is
# nothing for OneDrive's async sync to race or corrupt; it only ever READS the
# other subfolders to build the merged team view. Leave both unset for a
# solo/local setup (defaults to the local output\ folder and your OS username).
# TEAM_RUNS_ROOT=C:\Users\<you>\OneDrive - <Company>\ETL Test Runs
# TEAM_MEMBER=<your-name>          # defaults to your OS username if omitted
