# Copy to .env and fill in. .env is git-ignored. Never commit real credentials.
# connections.yaml references these via ${VAR_NAME}.

# --- Snowflake (target EDP) ---
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=svc_qa_user
# Auth: leave as externalbrowser for SSO (a browser opens once for login; the token
# is then cached). Set this empty to use password auth via SNOWFLAKE_PASSWORD.
SNOWFLAKE_AUTHENTICATOR=externalbrowser
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=QA_TEST_ROLE
SNOWFLAKE_WAREHOUSE=QA_WH
SNOWFLAKE_DATABASE=EDP
SNOWFLAKE_SCHEMA=GOLD
# Optional key-pair auth instead of password:
# SNOWFLAKE_PRIVATE_KEY_PATH=C:\\secure\\rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# --- MS Access (legacy Val DB) ---
ACCESS_DB_PATH=C:\\data\\ValDB.accdb
# ACCESS_DB_PASSWORD=

# --- SQL Server (other legacy) ---
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=LegacyDB
SQLSERVER_USER=
SQLSERVER_PASSWORD=
# Use Windows auth instead of user/password by setting SQLSERVER_TRUSTED=yes
SQLSERVER_TRUSTED=no

# --- Flat-file feeds (AlpInvest / Anaplan) ---
FILES_BASE_DIR=C:\\data\\feeds
